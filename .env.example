# COO Twin / Hermes — required secrets (NAMES ONLY, no values).
# Copy to a real secret store (Railway env vars for Hermes; .claude/settings.local.json
# locally) and fill in values. NEVER commit the filled-in version — only this template
# is tracked (.gitignore allowlists `!.env.example`).

# Notion internal integration token (ntn_…). System of record for tasks/CRM/activity/meetings.
NOTION_API_TOKEN=

# Anthropic API key (sk-ant-…). Used by the agent itself and the managed-agents webhook follow-up calls.
ANTHROPIC_API_KEY=

# MVE Telegram channel — see scripts/mve-telegram-send.ps1 / mve-telegram-receive.ps1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Workspace (Calendar + Tasks) is accessed via the `gws` CLI, which uses OAuth —
# NOT a single env var. On the host, run:
#   gws auth login --scopes calendar,tasks
# or provision client_secret_*.json + a cached token out-of-band. (client_secret_*.json
# is gitignored and must be supplied to the Hermes host separately.)

# Managed-agents webhook experiment only (whsec_…). Optional; leave unset unless running
# scripts/webhook-handler.py.
# ANTHROPIC_WEBHOOK_SIGNING_KEY=
