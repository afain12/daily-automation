#!/usr/bin/env bash
# Local enforcement of the validate gate.
#
# GitHub classic branch protection requires Pro on private repos, so the
# .github/workflows/validate.yml check is advisory-only here (it runs on PRs
# but can't block a merge). This hook gives the same gate real teeth locally:
# it runs the repo's three checks before every push and blocks on failure.
#
# Enable once per clone:
#     git config core.hooksPath .githooks
#
# Bypass in an emergency:  git push --no-verify
#
# Mirrors the steps in .github/workflows/validate.yml exactly.

set -uo pipefail
cd "$(git rev-parse --show-toplevel)" || exit 1

echo "[pre-push] running validation gate (self-test + skill_lint + streams_check)..."
fail=0

python scripts/capture_meeting_parse.py --self-test || { echo "[pre-push] parser self-test FAILED" >&2; fail=1; }
bash scripts/skill_lint.sh                          || { echo "[pre-push] skill_lint FAILED"         >&2; fail=1; }
python scripts/streams_check.py                     || { echo "[pre-push] streams_check FAILED (drift)" >&2; fail=1; }

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "[pre-push] BLOCKED: validation gate failed. Fix the issues above," >&2
  echo "           or bypass with: git push --no-verify" >&2
  exit 1
fi

echo "[pre-push] gate passed."
exit 0
